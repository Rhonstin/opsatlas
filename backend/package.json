{
  "name": "opsatlas-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "cli": "ts-node --transpile-only src/cli.ts",
    "test": "vitest run",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "knex migrate:latest --knexfile src/db/knexfile.ts",
    "migrate:prod": "knex migrate:latest --knexfile dist/db/knexfile.js",
    "migrate:rollback": "knex migrate:rollback --knexfile src/db/knexfile.ts",
    "migrate:make": "knex migrate:make --knexfile src/db/knexfile.ts"
  },
  "dependencies": {
    "@aws-sdk/client-cost-explorer": "^3.1032.0",
    "@aws-sdk/client-ec2": "^3.1034.0",
    "@aws-sdk/client-pricing": "^3.1034.0",
    "@google-cloud/bigquery": "^8.1.1",
    "@google-cloud/compute": "^4.5.0",
    "@google-cloud/resource-manager": "^5.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/speakeasy": "^2.0.10",
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "pg": "^8.12.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "qrcode": "^1.5.4",
    "speakeasy": "^2.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.9",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.3",
    "vitest": "^4.1.8"
  }
}
