PORT=4000
FRONTEND_URL=http://localhost:3000

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/opsatlas
# Or use individual fields:
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=opsatlas
# DB_USER=postgres
# DB_PASSWORD=postgres

# Generate with: openssl rand -hex 32
JWT_SECRET=change_me_to_a_long_random_secret

# Generate with: openssl rand -hex 16  (must be exactly 32 chars for AES-256)
ENCRYPTION_KEY=change_me_to_32_char_secret_here!
